{
  "name": "js-f-k-blog",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "lint:ts": "vue-tsc",
    "lint:js": "eslint .",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:css": "stylelint {.vitepress/**/*.{css,vue},**/articles/*.md}",
    "lint:css:fix": "npm run lint:css -- --fix",
    "lint:all": "npm run lint:ts && npm run lint:js && npm run lint:css",
    "test": "vitest --run",
    "i18n": "node ci/translations.ts"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "feed": "^5.2.0",
    "vite": "^8.0.3",
    "vitepress": "2.0.0-alpha.17",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@stylistic/stylelint-config": "^5.0.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.1.0",
    "gray-matter": "^4.0.3",
    "postcss-html": "^1.8.1",
    "postcss-markdown": "^1.3.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-rem-over-px": "^1.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
