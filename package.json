  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "lint:ts": "vue-tsc --noEmit",
    "lint:js": "eslint .",
    "lint:js:fix": "npm run lint:js -- --fix",
